#!/bin/sh
# Auto-increment APP_VERSION by 0.1 before each commit — men BARA om commiten
# faktiskt ändrar körbar kod (.html/.css/.js). Rena dokumentationscommits
# (t.ex. bara CHANGELOG.md) triggar ingen ny version.
# 1.9 → 2.0, otherwise 1.0 → 1.1 → 1.2 ...
# Synkar även cache-bust-parametern ?v= i index.html med nya versionen.

FILE="app.js"

CODE_CHANGED=$(git diff --cached --name-only -- '*.html' '*.css' '*.js')
if [ -z "$CODE_CHANGED" ]; then
  echo "Inga .html/.css/.js-filer i commiten — APP_VERSION oförändrad"
  exit 0
fi

CURRENT=$(grep -oE 'APP_VERSION = "[0-9]+\.[0-9]+"' "$FILE" | grep -oE '[0-9]+\.[0-9]+')
[ -z "$CURRENT" ] && exit 0

NEW=$(echo "$CURRENT" | awk -F. '{
  major = $1 + 0
  minor = $2 + 1
  if (minor >= 10) { major++; minor = 0 }
  printf "%d.%d", major, minor
}')

sed -i '' "s|APP_VERSION = \"$CURRENT\"|APP_VERSION = \"$NEW\"|" "$FILE"
git add "$FILE"

if [ -f index.html ]; then
  sed -i '' -E "s|(\.(css\|js)\?v=)[0-9]+\.[0-9]+|\1$NEW|g" index.html
  git add index.html
fi

echo "APP_VERSION: $CURRENT → $NEW"
